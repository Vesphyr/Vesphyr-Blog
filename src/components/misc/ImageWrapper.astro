---
import sharp from "sharp";
interface Props {
    id?: string;
    src: string;
    class?: string;
    alt?: string;
    position?: string;
    basePath?: string;
    loading?: "eager" | "lazy";
    width?: number;
    height?: number;
    widths?: number[];
    sizes?: string;
    fetchpriority?: "high" | "low" | "auto";
    decoding?: "async" | "sync" | "auto";
    aspectRatio?: string;
    blur?: boolean;
}
import { Image } from "astro:assets";
import { url } from "../../utils/url-utils";
const { id, src, alt, position = "center", basePath = "/", loading = "lazy", width, height, widths, sizes, fetchpriority = "auto", decoding = "async", aspectRatio, blur = false, } = Astro.props;
const className = Astro.props.class;
const isLocal = !(src.startsWith("/") ||
    src.startsWith("http") ||
    src.startsWith("https") ||
    src.startsWith("data:"));
const isPublic = src.startsWith("/");
let img: ImageMetadata | undefined;
let blurDataURL: string | undefined;
if (isLocal) {
    const files = import.meta.glob<ImageMetadata>("../../**", {
        import: "default",
    });
    const normalizedPath = (() => {
        const raw = `../../${basePath.replace(/^\/+/, "").replace(/\/+$/, "")}/${src.replace(/^\.\/+/, "")}`.replace(/\\/g, "/");
        const parts = raw.split("/");
        const stack: string[] = [];
        for (const seg of parts) {
            if (seg === "." || seg === "")
                continue;
            if (seg === "..") {
                if (stack.length > 0)
                    stack.pop();
                continue;
            }
            stack.push(seg);
        }
        return `../../${stack.join("/")}`;
    })();
    const file = files[normalizedPath];
    if (!file) {
        console.error(`\n[ERROR] Image file not found: src/${normalizedPath}`);
    }
    else {
        img = await file();
        if (blur && img) {
            try {
                const buffer = await sharp((img as any).fsPath)
                    .resize(8, undefined, { fit: "inside" })
                    .webp({ quality: 15 })
                    .toBuffer();
                blurDataURL = `data:image/webp;base64,${buffer.toString("base64")}`;
            }
            catch (e) {
                console.warn(`[ImageWrapper] Blur generation failed for ${src}:`, e);
            }
        }
    }
}
const imageClass = "w-full h-full object-cover";
const imageStyle = `object-position: ${position}`;
const isBilibiliImage = !isLocal && src.includes("hdslb.com");
const referrerPolicy = !isLocal && isBilibiliImage ? "no-referrer" : undefined;
---

<div
	id={id}
	class:list={[className, "overflow-hidden relative"]}
	style={aspectRatio ? `aspect-ratio: ${aspectRatio}` : undefined}
>
	
	{
		blurDataURL && (
			<div
				class="absolute inset-0 z-0 bg-cover bg-center blur-placeholder transition-opacity duration-500"
				style={`background-image: url(${blurDataURL})`}
			/>
		)
	}
	<div
		class="transition absolute inset-0 dark:bg-black/10 bg-opacity-50 pointer-events-none"
	>
	</div>
	{
		isLocal && img && (
			<Image
				src={img}
				alt={alt || ""}
				class={imageClass}
				style={imageStyle}
				loading={loading}
				width={width}
				height={height}
				widths={
					widths ||
					(img.width > 800
						? [400, 640, 768, 1024, img.width]
						: undefined)
				}
				sizes={sizes}
				fetchpriority={fetchpriority}
				decoding={decoding}
				class:list={[{ "relative z-10": blurDataURL }]}
			/>
		)
	}
	{
		!isLocal && (
			<img
				src={isPublic ? url(src) : src}
				alt={alt || ""}
				class={imageClass}
				style={imageStyle}
				loading={loading}
				referrerpolicy={referrerPolicy}
				crossorigin={isBilibiliImage ? "anonymous" : undefined}
				width={width}
				height={height}
				fetchpriority={fetchpriority}
				decoding={decoding}
			/>
		)
	}
</div>

<style>
	.blur-placeholder {
		filter: blur(8px) saturate(1.2);
		transform: scale(1.1);
	}
</style>
