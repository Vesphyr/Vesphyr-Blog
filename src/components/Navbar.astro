---
import { Icon } from "astro-icon/components";
import { navBarConfig, siteConfig } from "../config";
import { LinkPresets } from "../constants/link-presets";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import { LinkPreset, type NavBarLink } from "../types/config";
import { url } from "../utils/url-utils";
import ImageWrapper from "./misc/ImageWrapper.astro";
import LightDarkSwitch from "./LightDarkSwitch.svelte";
import DisplaySettings from "./widget/DisplaySettings.svelte";
import DropdownMenu from "./widget/DropdownMenu.astro";

const className = Astro.props.class;
const isHomePage = Astro.url.pathname === "/" || Astro.url.pathname === "";
let links: NavBarLink[] = navBarConfig.links.map(
  (item: NavBarLink | LinkPreset): NavBarLink => {
    if (typeof item === "number") {
      return LinkPresets[item];
    }
    return item;
  },
);
const mobileLinks = links.filter(
  (link) => !link.children?.length && link.url !== "/" && link.url !== "",
);
const logoSrc = siteConfig.navbarTitle?.logo ?? "";
const iconSrc = siteConfig.navbarTitle?.icon ?? "";
const hasNavbarLogo = Boolean(logoSrc);
const hasNavbarIcon = Boolean(iconSrc);
const navbarBrandText = siteConfig.navbarTitle?.text || siteConfig.title;
const isChineseSite = (siteConfig.lang || "").toLowerCase().startsWith("zh");
const primaryNavigationLabel = isChineseSite
  ? "\u4e3b\u5bfc\u822a"
  : "Primary navigation";
const displaySettingsLabel = isChineseSite
  ? "\u663e\u793a\u8bbe\u7f6e"
  : "Display settings";
const themeColorLabel = i18n(I18nKey.themeColor);
---

<nav
  id="navbar"
  class="z-50 onload-animation group"
  data-is-home={isHomePage}
  aria-label={primaryNavigationLabel}
>
  <div class="absolute h-8 left-0 right-0 -top-8 bg-transparent transition">
  </div>
  <div
    class:list={[
      className,
      "navbar-shell overflow-visible! max-w-(--page-width) h-18 mx-auto grid grid-cols-[auto_1fr_auto] items-center px-4 md:px-5",
    ]}
  >
    <a
      href={url("/")}
      class="navbar-brand btn-plain scale-animation rounded-lg h-10 md:h-13 px-3 md:px-4 font-bold active:scale-95 shrink-0 transition-all duration-300"
    >
      <div class="flex flex-row items-center text-md">
        {
          siteConfig.navbarTitle ? (
            siteConfig.navbarTitle.mode === "logo" && hasNavbarLogo ? (
              <ImageWrapper
                src={logoSrc}
                alt={siteConfig.navbarTitle.text}
                class="h-10 md:h-13 max-w-full object-contain transition-all duration-300"
                loading="lazy"
                width={200}
              />
            ) : (
              <>
                {hasNavbarIcon && (
                  <ImageWrapper
                    src={iconSrc}
                    alt={siteConfig.navbarTitle.text}
                    class="h-7 w-7 mr-2 object-contain"
                    loading="lazy"
                    width={28}
                  />
                )}
                <span class="navbar-brand-text">{navbarBrandText}</span>
              </>
            )
          ) : (
            <>
              <Icon
                name="material-symbols:home-pin-outline"
                class="text-[1.75rem] mr-2"
              />
              <span>{siteConfig.title}</span>
            </>
          )
        }
      </div>
    </a>
    <div
      id="navbar-links-container"
      class="navbar-links hidden lg:flex items-center justify-center gap-1 transition-all duration-300"
    >
      {
        links.map((l) => {
          return <DropdownMenu link={l} />;
        })
      }
    </div>
    <div class="navbar-actions flex items-center gap-1">
      <div
        class="mobile-navbar-links flex items-center gap-1 shrink-0 lg:hidden"
      >
        {
          mobileLinks.map((link) => (
            <a
              href={link.external ? link.url : url(link.url)}
              target={link.external ? "_blank" : null}
              rel={link.external ? "noopener noreferrer" : null}
              aria-label={link.name}
              title={link.name}
              class="mobile-nav-link btn-plain scale-animation rounded-lg active:scale-90 flex items-center justify-center"
            >
              {link.icon && (
                <Icon
                  name={link.icon}
                  class="navbar-link-icon mobile-nav-link-icon shrink-0"
                />
              )}
              <span class="mobile-nav-label">{link.name}</span>
            </a>
          ))
        }
      </div>

      {
        !siteConfig.themeColor.fixed && (
          <button
            type="button"
            aria-label={displaySettingsLabel}
            aria-controls="display-setting"
            aria-haspopup="dialog"
            class="mobile-display-settings btn-plain scale-animation rounded-lg w-8 h-8 lg:w-9 lg:h-9 active:scale-90 flex items-center justify-center"
            id="display-settings-switch"
            title={themeColorLabel}
          >
            <Icon
              name="material-symbols:palette-outline"
              class="navbar-action-icon mobile-nav-link-icon text-[1rem] lg:text-[1.25rem]"
            />
          </button>
        )
      }

      <div
        class="theme-switch-wrap w-8 h-8 md:w-9 md:h-9 flex items-center justify-center shrink-0"
      >
        <LightDarkSwitch client:idle />
      </div>
    </div>
    <DisplaySettings client:idle />
  </div>
</nav>

<script>
  import "../scripts/navbar/navbar-panels.ts";
</script>
