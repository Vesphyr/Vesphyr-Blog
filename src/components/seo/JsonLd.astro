---
import { siteConfig, profileConfig } from "@/config";
import { url } from "@/utils/url-utils";
interface Props {
    type?: "website" | "article" | "person";
    article?: {
        title: string;
        description?: string;
        published?: Date;
        modified?: Date;
        image?: string;
    };
}
const { type = "website", article } = Astro.props;
const websiteSchema = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteConfig.title,
    url: siteConfig.siteURL,
    description: siteConfig.subtitle,
    publisher: {
        "@type": "Organization",
        name: siteConfig.title,
        url: siteConfig.siteURL,
        logo: {
            "@type": "ImageObject",
            url: url("/favicon/favicon.png"),
        },
    },
};
const personSchema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: profileConfig.name,
    url: siteConfig.siteURL,
    image: profileConfig.avatar
        ? url(profileConfig.avatar.startsWith("/")
            ? profileConfig.avatar
            : `/src/assets/${profileConfig.avatar}`)
        : undefined,
    description: profileConfig.bio,
    sameAs: profileConfig.links.map((link) => link.url),
};
const articleSchema = article
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: article.title,
        description: article.description,
        image: article.image ? url(article.image) : undefined,
        datePublished: article.published?.toISOString(),
        dateModified: article.modified?.toISOString() || article.published?.toISOString(),
        author: {
            "@type": "Person",
            name: profileConfig.name,
            url: siteConfig.siteURL,
        },
        publisher: {
            "@type": "Organization",
            name: siteConfig.title,
            url: siteConfig.siteURL,
            logo: {
                "@type": "ImageObject",
                url: url("/favicon/favicon.png"),
            },
        },
        mainEntityOfPage: {
            "@type": "WebPage",
            "@id": Astro.url.href,
        },
    }
    : null;
const schemas = [];
if (type === "website" || type === "article") {
    schemas.push(websiteSchema);
}
if (type === "person" || type === "article") {
    schemas.push(personSchema);
}
if (type === "article" && articleSchema && article) {
    schemas.push(articleSchema);
    schemas.push({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
            { "@type": "ListItem", position: 1, name: siteConfig.title, item: siteConfig.siteURL },
            { "@type": "ListItem", position: 2, name: article.title, item: Astro.url.href },
        ],
    });
}
---

{schemas.map((schema) => (
	<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
