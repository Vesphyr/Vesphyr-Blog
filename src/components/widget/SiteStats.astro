---
import { Icon } from "astro-icon/components";
import { siteConfig } from "../../config";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { getSortedPosts } from "../../utils/content-utils";
import { getRunningDays } from "../../utils/date-utils";
import WidgetLayout from "./WidgetLayout.astro";

interface Props {
  class?: string;
  style?: string;
}

const { class: className, style } = Astro.props;

const siteStartDate = siteConfig.siteStartDate || "2025-01-01";
const timeZoneOffset = siteConfig.timeZone || 0;
const initialRunningDays = getRunningDays(siteStartDate, timeZoneOffset);
const posts = await getSortedPosts();

let totalWords = 0;
for (const post of posts) {
  if (post.body) {
    let text = post.body;

    text = text.replace(/```[\s\S]*?```/g, "");
    text = text.replace(/`[^`]+`/g, "");

    const cjkPattern =
      /[\u4e00-\u9fa5\u3040-\u309f\u30a0-\u30ff\uac00-\ud7af\u3000-\u303f\uff00-\uffef]/g;

    const cjkMatches = text.match(cjkPattern);
    const cjkCount = cjkMatches ? cjkMatches.length : 0;
    const nonCjkText = text.replace(cjkPattern, " ");
    const nonCjkWords = nonCjkText
      .split(/\s+/)
      .filter((word) => word.trim().length > 0);

    totalWords += cjkCount + nonCjkWords.length;
  }
}

function formatNumber(num: number): string {
  return num.toLocaleString();
}

const stats = [
  {
    icon: "material-symbols:article-outline",
    label: i18n(I18nKey.siteStatsPostCount),
    value: posts.length,
  },
  {
    icon: "material-symbols:text-ad-outline-rounded",
    label: i18n(I18nKey.siteStatsTotalWords),
    value: totalWords,
    formatted: true,
  },
  {
    icon: "material-symbols:calendar-clock-outline",
    label: i18n(I18nKey.siteStatsRunningDays),
    value: initialRunningDays,
    suffix: i18n(I18nKey.siteStatsDays).replace("{days}", ""),
    dynamic: true,
    id: "running-days",
  },
];
---

<WidgetLayout
  name={i18n(I18nKey.siteStats)}
  id="site-stats"
  class={className}
  style={style}
>
  <div class="flex flex-col gap-1">
    {/* 第一行：文章数 和 总字数 并排 */}
    <div class="flex items-center gap-2 px-2 py-2">
      <div class="flex flex-1 items-center justify-between px-1 py-1">
        <div class="flex items-center gap-2">
          <div class="text-(--primary) text-xl shrink-0">
            <Icon name={stats[0].icon} />
          </div>
          <span class="text-75 font-medium text-base leading-tight">
            {stats[0].label}
          </span>
        </div>
        <span class="text-base font-bold text-90 ml-2">
          {stats[0].value}
        </span>
      </div>
      <div class="flex flex-1 items-center justify-between px-1 py-1">
        <div class="flex items-center gap-2">
          <div class="text-(--primary) text-xl shrink-0">
            <Icon name={stats[1].icon} />
          </div>
          <span class="text-75 font-medium text-base leading-tight">
            {stats[1].label}
          </span>
        </div>
        <span class="text-base font-bold text-90 ml-2">
          {formatNumber(stats[1].value)}
        </span>
      </div>
    </div>

    {/* 其余行：运行天数等 */}
    {
      stats.slice(2).map((stat) => (
        <div class="flex items-center justify-between px-2 py-2">
          <div class="flex items-center gap-2.5 flex-1 min-w-0">
            <div class="text-(--primary) text-xl shrink-0">
              <Icon name={stat.icon} />
            </div>
            <span class="text-75 font-medium text-base wrap-break-word leading-tight">
              {stat.label}
            </span>
          </div>
          <div class="flex items-center ml-3 shrink-0">
            <span class="text-base font-bold text-90" data-stat-id={stat.id}>
              {stat.formatted ? formatNumber(stat.value) : stat.value}
            </span>
            {stat.suffix && (
              <span class="text-base text-50 ml-1">{stat.suffix}</span>
            )}
          </div>
        </div>
      ))
    }
  </div>
</WidgetLayout>

<script
  is:inline
  define:vars={{
    siteStartDate,
    timeZoneOffset,
  }}
>
  function updateDynamicStats() {
    const [year, month, day] = siteStartDate
      .split("-")
      .map((value) => Number.parseInt(value, 10));
    if (!year || !month || !day) return;

    const startTime = Date.UTC(year, month - 1, day, -timeZoneOffset, 0, 0, 0);
    const currentTime = Date.now();
    const dayInMs = 24 * 60 * 60 * 1000;
    const startDayIndex = Math.floor(
      (startTime + timeZoneOffset * 60 * 60 * 1000) / dayInMs,
    );
    const currentDayIndex = Math.floor(
      (currentTime + timeZoneOffset * 60 * 60 * 1000) / dayInMs,
    );
    const diffDays = Math.max(0, currentDayIndex - startDayIndex);

    const runningDaysElements = document.querySelectorAll(
      '[data-stat-id="running-days"]',
    );
    if (runningDaysElements.length > 0) {
      runningDaysElements.forEach((element) => {
        element.textContent = diffDays.toString();
      });
    }
  }

  updateDynamicStats();
  setInterval(updateDynamicStats, 60 * 60 * 1000);
</script>
