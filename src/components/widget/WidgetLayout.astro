---
import { Icon } from "astro-icon/components";
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

interface Props {
  id: string;
  name?: string;
  isCollapsed?: boolean;
  collapsedHeight?: string;
  class?: string;
  style?: string;
}
const { id, name, isCollapsed, collapsedHeight, style } = Astro.props;
const className = Astro.props.class;
---

<widget-layout
  data-id={id}
  data-is-collapsed={String(isCollapsed)}
  class:list={["pb-4 card-base", className]}
  style={style}
>
  {
    name && (
      <div
        class="font-bold transition text-lg leading-6 text-90 relative ml-8 mt-4 mb-2 flex items-center gap-2
        before:w-1 before:h-4 before:rounded-md before:bg-(--primary)
        before:absolute before:left-[-16px] before:top-[5.5px]"
      >
        {name}
        <slot name="title-icon" />
      </div>
    )
  }
  <div
    id={id}
    class:list={[
      "collapse-wrapper px-4 overflow-hidden",
      { collapsed: isCollapsed },
    ]}
  >
    <slot />
  </div>
  {
    isCollapsed && (
      <div class="expand-btn px-4 -mb-2">
        <button class="btn-plain rounded-lg w-full h-9">
          <div class="text-(--primary) flex items-center justify-center gap-2 -translate-x-2">
            <Icon name="material-symbols:more-horiz" class="text-[1.75rem]" />{" "}
            {i18n(I18nKey.more)}
          </div>
        </button>
      </div>
    )
  }
</widget-layout>

<style define:vars={{ collapsedHeight }}>
  widget-layout {
    content-visibility: auto;
    contain-intrinsic-size: 18rem;
  }

  :global(widget-layout[data-id="categories"]) {
    content-visibility: visible;
    contain-intrinsic-size: none;
  }

  .collapsed {
    height: var(--collapsedHeight);
  }
</style>

<script>
  class WidgetLayout extends HTMLElement {
    connectedCallback() {
      if (this.dataset.widgetLayoutReady === "true") return;
      this.dataset.widgetLayoutReady = "true";
      if (this.dataset.isCollapsed !== "true") return;

      const id = this.dataset.id;
      if (!id) return;

      const btn = this.querySelector(".expand-btn");
      const wrapper = this.querySelector(`#${CSS.escape(id)}`);
      if (!(btn instanceof HTMLElement) || !(wrapper instanceof HTMLElement))
        return;

      btn.addEventListener(
        "click",
        () => {
          wrapper.classList.remove("collapsed");
          btn.classList.add("hidden");
        },
        { once: true },
      );
    }
  }

  if (!customElements.get("widget-layout")) {
    customElements.define("widget-layout", WidgetLayout);
  }
</script>
