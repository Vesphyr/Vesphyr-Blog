---
import { Icon } from "astro-icon/components";
---

<button
	id="back-to-top-btn"
	class="back-to-top-btn"
	aria-label="Back to top"
>
	<Icon name="material-symbols:arrow-upward-rounded" class="text-3xl" />
</button>

<style>
	.back-to-top-btn {
		position: fixed;
		left: 1.5rem;
		bottom: 2rem;
		z-index: 40;
		width: 4rem;
		height: 4rem;
		border-radius: 0.75rem;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--primary);
		background: var(--card-bg);
		border: 1px solid var(--line-divider);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		opacity: 0.85;
		cursor: pointer;
		transition:
			opacity 0.3s ease,
			transform 0.3s ease;
	}

	.back-to-top-btn:hover {
		background: var(--btn-plain-bg-hover);
		opacity: 1;
		transform: translateY(-2px);
	}

	@media (max-width: 768px) {
		.back-to-top-btn {
			left: 1rem;
			bottom: 1rem;
			width: 3rem;
			height: 3rem;
		}
	}

	
	@media (prefers-reduced-motion: reduce) {
		.back-to-top-btn {
			transition-duration: 0.01ms !important;
		}
	}
</style>

<script>
	import { registerPageScript } from "../../scripts/page-lifecycle.ts";
	class BackToTop {
	    private btn: HTMLElement | null;
	    private handleClick = () => {
	        window.scrollTo({ top: 0, behavior: "smooth" });
	    };
	    constructor() {
	        this.btn = document.getElementById("back-to-top-btn");
	        this.init();
	    }
	    private init() {
	        this.btn?.addEventListener("click", this.handleClick);
	    }
	    destroy() {
	        this.btn?.removeEventListener("click", this.handleClick);
	    }
	}
	registerPageScript("back-to-top", {
	    shouldRun() {
	        return document.getElementById("back-to-top-btn") !== null;
	    },
	    init() {
	        const instance = new BackToTop();
	        return () => instance.destroy();
	    },
	});
</script>
