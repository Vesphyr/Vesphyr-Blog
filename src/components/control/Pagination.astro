---
import type { Page } from "astro";
import { Icon } from "astro-icon/components";
import { url } from "../../utils/url-utils";
interface Props {
    page: Page;
    class?: string;
    style?: string;
}
const { page, style } = Astro.props;
const HIDDEN = -1;
const className = Astro.props.class;
const ADJ_DIST = 2;
const VISIBLE = ADJ_DIST * 2 + 1;
let count = 1;
let l = page.currentPage;
let r = page.currentPage;
while (0 < l - 1 && r + 1 <= page.lastPage && count + 2 <= VISIBLE) {
    count += 2;
    l--;
    r++;
}
while (0 < l - 1 && count < VISIBLE) {
    count++;
    l--;
}
while (r + 1 <= page.lastPage && count < VISIBLE) {
    count++;
    r++;
}
let pages: number[] = [];
if (l > 1)
    pages.push(1);
if (l === 3)
    pages.push(2);
if (l > 3)
    pages.push(HIDDEN);
for (let i = l; i <= r; i++)
    pages.push(i);
if (r < page.lastPage - 2)
    pages.push(HIDDEN);
if (r === page.lastPage - 2)
    pages.push(page.lastPage - 1);
if (r < page.lastPage)
    pages.push(page.lastPage);
const getPageUrl = (p: number) => {
    if (p === 1)
        return "/";
    return `/${p}/`;
};
const previousPageUrl = page.url.prev ? url(page.url.prev) : undefined;
const nextPageUrl = page.url.next ? url(page.url.next) : undefined;
---

<nav
	class:list={[className, "flex flex-row gap-3 justify-center"]}
	style={style}
	aria-label="Pagination"
>
	{
		previousPageUrl ? (
			<a
				href={previousPageUrl}
				aria-label="Previous Page"
				class="btn-card overflow-hidden rounded-lg text-(--primary) w-11 h-11"
			>
				<Icon
					name="material-symbols:chevron-left-rounded"
					class="text-[1.75rem]"
				/>
			</a>
		) : (
			<span
				aria-hidden="true"
				class="btn-card overflow-hidden rounded-lg text-(--primary) w-11 h-11 opacity-50 cursor-default pointer-events-none"
			>
				<Icon
					name="material-symbols:chevron-left-rounded"
					class="text-[1.75rem]"
				/>
			</span>
		)
	}
	<div
		class="bg-(--card-bg) flex flex-row rounded-lg items-center text-black dark:text-white font-bold"
	>
		{
			pages.map((p) => {
				if (p == HIDDEN)
					return (
						<span aria-hidden="true">
							<Icon name="material-symbols:more-horiz" class="mx-1" />
						</span>
					);
				if (p == page.currentPage)
					return (
						<span
							aria-current="page"
							class="h-11 w-11 rounded-lg bg-(--primary) flex items-center justify-center
                    font-bold text-white"
						>
							{p}
						</span>
					);
				return (
					<a
						href={url(getPageUrl(p))}
						aria-label={`Page ${p}`}
						class="btn-card w-11 h-11 rounded-lg overflow-hidden active:scale-[0.85]"
					>
						{p}
					</a>
				);
			})
		}
	</div>
	{
		nextPageUrl ? (
			<a
				href={nextPageUrl}
				aria-label="Next Page"
				class="btn-card overflow-hidden rounded-lg text-(--primary) w-11 h-11"
			>
				<Icon
					name="material-symbols:chevron-right-rounded"
					class="text-[1.75rem]"
				/>
			</a>
		) : (
			<span
				aria-hidden="true"
				class="btn-card overflow-hidden rounded-lg text-(--primary) w-11 h-11 opacity-50 cursor-default pointer-events-none"
			>
				<Icon
					name="material-symbols:chevron-right-rounded"
					class="text-[1.75rem]"
				/>
			</span>
		)
	}
</nav>
