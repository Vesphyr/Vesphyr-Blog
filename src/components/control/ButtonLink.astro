---
interface Props {
	badge?: string;
	url?: string;
	label?: string;
}
const { badge, url, label } = Astro.props;
---

<a href={url} aria-label={label} class="block">
	<span
		class:list={`
			flex
			w-full
			h-10
			items-center
			rounded-lg
			bg-none
			hover:bg-(--btn-plain-bg-hover)
			active:bg-(--btn-plain-bg-active)
			transition-all
			pl-2
			pr-2
			hover:pl-3
			text-75
			hover:text-(--primary)
		`}
	>
		<span class="flex w-full items-center justify-between relative">
			<span
				class="overflow-hidden text-left whitespace-nowrap text-ellipsis"
			>
				<slot />
			</span>
			{
				badge !== undefined && badge !== null && badge !== "" && (
					<span
						class="transition px-2 h-7 ml-4 min-w-8 rounded-lg text-[13px] font-bold
                    text-(--btn-content) dark:text-(--deep-text)!
                    bg-(--btn-plain-bg-hover) dark:bg-(--primary)!
                    flex items-center justify-center"
					>
						{badge}
					</span>
				)
			}
		</span>
	</span>
</a>
