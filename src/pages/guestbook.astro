---
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="留言" description="Vesphyr 留言板">
  <section class="guestbook-shell card-base">
    <header class="guestbook-header">
      <p class="guestbook-eyebrow">Guestbook</p>
      <h1>留言板</h1>
      <p class="guestbook-intro">
        可以在这里留下想说的话。
      </p>
    </header>

    <form id="guestbook-form" class="guestbook-form" autocomplete="on">
      <div class="guestbook-field-grid">
        <label>
          <span>昵称</span>
          <input
            id="guestbook-name"
            name="name"
            type="text"
            maxlength="32"
            required
            placeholder="你的名字"
          />
        </label>

        <label>
          <span>链接</span>
          <input
            id="guestbook-website"
            name="website"
            type="url"
            maxlength="160"
            placeholder="https://example.com"
          />
        </label>
      </div>

      <label class="guestbook-message-field">
        <span>内容</span>
        <textarea
          id="guestbook-message"
          name="message"
          maxlength="500"
          required
          rows="5"
          placeholder="写点什么..."
        ></textarea>
        <span id="guestbook-counter" class="guestbook-counter" aria-live="polite">0/500</span>
      </label>

      <label class="guestbook-honeypot" aria-hidden="true">
        <span>请留空</span>
        <input id="guestbook-company" name="company" type="text" tabindex="-1" />
      </label>

      <div class="guestbook-actions">
        <p id="guestbook-status" class="guestbook-status" role="status"></p>
        <button id="guestbook-submit" class="btn-regular" type="submit">
          发布留言
        </button>
      </div>
    </form>

    <div id="guestbook-admin-panel" class="guestbook-admin-panel" hidden>
      <input
        id="admin-token-input"
        type="password"
        class="admin-token-input"
        placeholder="管理员 Token"
        autocomplete="off"
      />
      <button id="admin-login-btn" class="btn-regular" type="button">进入管理模式</button>
    </div>

    <div class="guestbook-list-header">
      <h2>最近留言<span id="guestbook-count" class="guestbook-count" aria-live="polite"></span></h2>
      <button id="guestbook-refresh" class="btn-plain" type="button">
        刷新
      </button>
    </div>

    <div id="guestbook-list" class="guestbook-list" aria-live="polite">
      <div class="guestbook-empty">正在加载留言...</div>
    </div>
    <button id="load-more-btn" class="btn-plain w-full py-2 mt-2 rounded-lg text-sm" style="display:none">加载更多</button>
  </section>
</MainGridLayout>

<script>
  // 所有逻辑包裹在 astro:page-load 中，确保 View Transitions 导航后重新初始化。
  // 模块脚本只执行一次，但 listener 每次 page-load 都会触发；
  // 旧 DOM 元素被 View Transitions 替换后，旧监听器随脱离的节点被 GC，不会累积。
  document.addEventListener("astro:page-load", () => {
    const form = document.querySelector<HTMLFormElement>("#guestbook-form");
    if (!form) return; // 不在留言板页面时不执行

  type GuestbookEntry = {
    id: number;
    name: string;
    website: string;
    message: string;
    createdAt: string;
  };

  const list = document.querySelector<HTMLDivElement>("#guestbook-list");
  const status = document.querySelector<HTMLParagraphElement>("#guestbook-status");
  const submitButton =
    document.querySelector<HTMLButtonElement>("#guestbook-submit");
  const refreshButton =
    document.querySelector<HTMLButtonElement>("#guestbook-refresh");
  const messageInput =
    document.querySelector<HTMLTextAreaElement>("#guestbook-message");
  const nameInput =
    document.querySelector<HTMLInputElement>("#guestbook-name");
  const websiteInput =
    document.querySelector<HTMLInputElement>("#guestbook-website");
  const counter =
    document.querySelector<HTMLSpanElement>("#guestbook-counter");
  const countLabel =
    document.querySelector<HTMLSpanElement>("#guestbook-count");
  const adminPanel =
    document.querySelector<HTMLDivElement>("#guestbook-admin-panel");

  const DRAFT_KEY = "guestbook:draft";
  const ADMIN_TOKEN_KEY = "guestbook:admin-token";
  let isAdminMode = false;
  let currentOffset = 0;

  function getAdminToken(): string | null {
    try {
      return sessionStorage.getItem(ADMIN_TOKEN_KEY);
    } catch {
      return null;
    }
  }

  function setAdminToken(token: string) {
    try {
      sessionStorage.setItem(ADMIN_TOKEN_KEY, token);
    } catch {
      // sessionStorage 不可用时静默降级
    }
  }

  function clearAdminToken() {
    try {
      sessionStorage.removeItem(ADMIN_TOKEN_KEY);
    } catch {
      // ignore
    }
  }

  function saveDraft() {
    try {
      const draft = {
        name: nameInput?.value ?? "",
        website: websiteInput?.value ?? "",
        message: messageInput?.value ?? "",
      };
      localStorage.setItem(DRAFT_KEY, JSON.stringify(draft));
    } catch {
      // localStorage 不可用时静默降级
    }
  }

  function loadDraft() {
    try {
      const raw = localStorage.getItem(DRAFT_KEY);
      if (!raw) return;
      const draft = JSON.parse(raw) as Partial<{
        name: string;
        website: string;
        message: string;
      }>;
      if (nameInput && typeof draft.name === "string") nameInput.value = draft.name;
      if (websiteInput && typeof draft.website === "string") websiteInput.value = draft.website;
      if (messageInput && typeof draft.message === "string") messageInput.value = draft.message;
      updateCounter();
    } catch {
      // ignore
    }
  }

  function clearDraft() {
    try {
      localStorage.removeItem(DRAFT_KEY);
    } catch {
      // ignore
    }
  }

  async function handleDelete(id: number, btn: HTMLButtonElement) {
    const token = getAdminToken();
    if (!token) return;
    if (!confirm("确定删除这条留言吗？")) return;
    btn.disabled = true;
    try {
      const res = await fetch(`/api/guestbook?id=${id}`, {
        method: "DELETE",
        headers: { "x-admin-token": token },
      });
      const data = await res.json();
      if (!res.ok || !data.ok) {
        if (res.status === 401) {
          // token 已失效，退出管理模式
          clearAdminToken();
          isAdminMode = false;
          if (adminPanel) adminPanel.hidden = true;
          await loadMessages();
          setStatus("管理员 Token 已失效，已退出管理模式。", "error");
          return;
        }
        throw new Error(data.message || "删除失败。");
      }
      const card = btn.closest(".guestbook-item");
      card?.remove();
      // 总数 -1
      const currentText = countLabel?.textContent ?? "";
      const match = currentText.match(/(\d+)/);
      if (match) {
        const n = Math.max(0, parseInt(match[1], 10) - 1);
        updateCount(n);
      }
    } catch (error) {
      setStatus(error instanceof Error ? error.message : "删除失败。", "error");
      btn.disabled = false;
    }
  }

  function setStatus(message: string, type = "info") {
    if (!status) return;
    status.textContent = message;
    status.dataset.type = type;
  }

  function updateCount(total?: number) {
    if (!countLabel) return;
    countLabel.textContent =
      typeof total === "number" && total > 0 ? ` · ${total}` : "";
  }

  function updateCounter() {
    if (!counter || !messageInput) return;
    const len = messageInput.value.length;
    counter.textContent = `${len}/500`;
    counter.dataset.state = len >= 450 ? "near" : "ok";
  }

  messageInput?.addEventListener("input", () => {
    updateCounter();
    saveDraft();
  });
  nameInput?.addEventListener("input", saveDraft);
  websiteInput?.addEventListener("input", saveDraft);

  messageInput?.addEventListener("keydown", (event) => {
    if ((event.ctrlKey || event.metaKey) && event.key === "Enter") {
      event.preventDefault();
      form?.requestSubmit();
    }
  });

  function formatDate(value: string) {
    try {
      return new Intl.DateTimeFormat("zh-CN", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
      }).format(new Date(value));
    } catch {
      return "";
    }
  }

  function formatRelative(value: string) {
    const then = new Date(value).getTime();
    if (!Number.isFinite(then)) return formatDate(value);
    const diff = Date.now() - then;
    if (diff < 60_000) return "刚刚";
    if (diff < 3_600_000) return `${Math.floor(diff / 60_000)} 分钟前`;
    if (diff < 86_400_000) return `${Math.floor(diff / 3_600_000)} 小时前`;
    if (diff < 604_800_000) return `${Math.floor(diff / 86_400_000)} 天前`;
    return formatDate(value);
  }

  // 将文本中的 URL 转为 <a>，其余保持纯文本节点；全程 DOM API，不用 innerHTML
  function createMessageContent(text: string): DocumentFragment {
    const fragment = document.createDocumentFragment();
    const urlRegex = /(https?:\/\/[^\s<>"']+)/gi;
    let lastIndex = 0;
    let match: RegExpExecArray | null;
    while ((match = urlRegex.exec(text)) !== null) {
      if (match.index > lastIndex) {
        fragment.appendChild(
          document.createTextNode(text.slice(lastIndex, match.index)),
        );
      }
      const url = match[0];
      const a = document.createElement("a");
      a.href = url;
      a.target = "_blank";
      a.rel = "noopener noreferrer";
      a.className = "guestbook-inline-link";
      a.textContent = url;
      fragment.appendChild(a);
      lastIndex = match.index + url.length;
    }
    if (lastIndex < text.length) {
      fragment.appendChild(document.createTextNode(text.slice(lastIndex)));
    }
    return fragment;
  }

  function hashString(str: string): number {
    let hash = 0;
    for (let i = 0; i < str.length; i++) {
      hash = ((hash << 5) - hash) + str.charCodeAt(i);
      hash |= 0;
    }
    // 使用无符号右移确保非负，避免 Math.abs(INT_MIN) 返回负值的边界 bug
    return hash >>> 0;
  }

  function createAvatar(name: string): HTMLElement {
    const avatar = document.createElement("span");
    avatar.className = "guestbook-avatar";
    const trimmed = name.trim();
    avatar.textContent = trimmed ? trimmed.charAt(0).toUpperCase() : "?";
    const hue = hashString(name) % 360;
    avatar.style.backgroundColor = `oklch(0.62 0.14 ${hue})`;
    return avatar;
  }

  function createMessageCard(entry: GuestbookEntry, isAdmin = false) {
    const article = document.createElement("article");
    article.className = "guestbook-item";
    article.dataset.id = String(entry.id);

    const header = document.createElement("div");
    header.className = "guestbook-item-header";

    const left = document.createElement("div");
    left.className = "guestbook-item-left";
    left.append(createAvatar(entry.name));

    const name = document.createElement(entry.website ? "a" : "span");
    name.className = "guestbook-item-name";
    name.textContent = entry.name;
    if (entry.website && /^https?:\/\//i.test(entry.website) && name instanceof HTMLAnchorElement) {
      name.href = entry.website;
      name.target = "_blank";
      name.rel = "noopener noreferrer";
    }
    left.append(name);

    const time = document.createElement("time");
    time.className = "guestbook-item-time";
    time.dateTime = entry.createdAt;
    time.textContent = formatRelative(entry.createdAt);
    time.title = formatDate(entry.createdAt);

    const message = document.createElement("p");
    message.className = "guestbook-item-message";
    message.appendChild(createMessageContent(entry.message));

    header.append(left, time);

    if (isAdmin) {
      const delBtn = document.createElement("button");
      delBtn.type = "button";
      delBtn.className = "guestbook-item-delete";
      delBtn.textContent = "删除";
      delBtn.setAttribute("aria-label", `删除 ${entry.name} 的留言`);
      delBtn.addEventListener("click", () => handleDelete(entry.id, delBtn));
      header.append(delBtn);
    }

    article.append(header, message);
    return article;
  }

  function renderMessages(entries: GuestbookEntry[]) {
    if (!list) return;
    list.replaceChildren();
    if (!entries.length) {
      const empty = document.createElement("div");
      empty.className = "guestbook-empty";
      empty.textContent = "还没有留言。";
      list.append(empty);
      return;
    }

    entries.forEach((entry) => list.append(createMessageCard(entry, isAdminMode)));
  }

  function appendMessages(entries: GuestbookEntry[]) {
    if (!list || !entries.length) return;
    const empty = list.querySelector(".guestbook-empty");
    if (empty) empty.remove();
    entries.forEach((entry) => list.append(createMessageCard(entry, isAdminMode)));
  }

  function updateLoadMoreButton(hasMore: boolean) {
    const btn = document.getElementById("load-more-btn");
    if (btn) btn.style.display = hasMore ? "" : "none";
  }

  async function loadMessages(reset = true, scrollToTop = false) {
    setStatus("");
    if (reset) currentOffset = 0;
    try {
      const response = await fetch(`/api/guestbook?limit=20&offset=${currentOffset}`, {
        headers: { accept: "application/json" },
      });
      const data = await response.json();
      if (!response.ok || !data.ok) {
        throw new Error(data.message || "留言加载失败。");
      }
      if (reset) {
        renderMessages(data.entries ?? []);
      } else {
        appendMessages(data.entries ?? []);
      }
      currentOffset += (data.entries ?? []).length;
      updateLoadMoreButton(data.hasMore ?? false);
      updateCount(data.total);
      if (scrollToTop && list?.firstElementChild instanceof Element) {
        // 等待浏览器完成布局后再滚动，避免定位到错误位置
        requestAnimationFrame(() => {
          list?.firstElementChild?.scrollIntoView({
            behavior: "smooth",
            block: "start",
          });
        });
      }
    } catch (error) {
      if (reset) renderMessages([]);
      setStatus(error instanceof Error ? error.message : "留言加载失败。", "error");
    }
  }

  document.getElementById("load-more-btn")?.addEventListener("click", () => loadMessages(false));

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!(form instanceof HTMLFormElement)) return;

    const formData = new FormData(form);
    const payload = {
      name: String(formData.get("name") || ""),
      website: String(formData.get("website") || ""),
      message: String(formData.get("message") || ""),
      company: String(formData.get("company") || ""),
    };

    submitButton?.setAttribute("disabled", "true");
    setStatus("正在发布...", "info");

    try {
      const response = await fetch("/api/guestbook", {
        method: "POST",
        headers: {
          accept: "application/json",
          "content-type": "application/json",
        },
        body: JSON.stringify(payload),
      });
      const data = await response.json();
      if (!response.ok || !data.ok) {
        throw new Error(data.message || "留言发布失败。");
      }
      form.reset();
      updateCounter();
      clearDraft();
      setStatus("留言已发布。", "success");
      await loadMessages(true, true);
    } catch (error) {
      setStatus(error instanceof Error ? error.message : "留言发布失败。", "error");
    } finally {
      submitButton?.removeAttribute("disabled");
    }
  });

  refreshButton?.addEventListener("click", () => {
    loadMessages();
  });

  // 草稿回填（honeypot 字段不回填）
  loadDraft();

  // 管理员模式：URL 带 ?admin=1 时显示登录面板；sessionStorage 已有 token 则直接进入管理模式
  function initAdminMode() {
    if (!adminPanel) return;
    const url = new URL(window.location.href);
    const adminRequested = url.searchParams.has("admin");

    const existingToken = getAdminToken();
    if (existingToken) {
      enterAdminMode();
      // 不在此处 loadMessages，交给末尾统一调用
      return;
    }

    if (adminRequested) {
      adminPanel.hidden = false;
      const input = adminPanel.querySelector<HTMLInputElement>("#admin-token-input");
      const btn = adminPanel.querySelector<HTMLButtonElement>("#admin-login-btn");
      btn?.addEventListener("click", () => {
        const token = input?.value.trim();
        if (!token) {
          input?.focus();
          return;
        }
        setAdminToken(token);
        enterAdminMode();
        // 登录后需重新渲染显示删除按钮
        loadMessages();
      });
      input?.addEventListener("keydown", (e) => {
        if (e.key === "Enter") btn?.click();
      });
    }
  }

  function enterAdminMode() {
    // token 已存入 sessionStorage，删除时由 handleDelete 取用；
    // token 是否有效在首次删除时才验证（401 则退出管理模式）
    isAdminMode = true;
    if (adminPanel) {
      adminPanel.hidden = false;
      adminPanel.innerHTML = "";
      const tag = document.createElement("span");
      tag.className = "admin-active-tag";
      tag.textContent = "管理模式已开启";
      const exitBtn = document.createElement("button");
      exitBtn.type = "button";
      exitBtn.className = "btn-plain";
      exitBtn.textContent = "退出管理";
      exitBtn.addEventListener("click", () => {
        clearAdminToken();
        isAdminMode = false;
        adminPanel.hidden = true;
        loadMessages();
      });
      adminPanel.append(tag, exitBtn);
    }
  }

  initAdminMode();
  loadMessages();
  }); // end astro:page-load
</script>

<style>
  .guestbook-shell {
    padding: 2rem;
    border-radius: var(--radius-large);
  }

  .guestbook-header {
    margin-bottom: 1.75rem;
  }

  .guestbook-eyebrow {
    margin: 0 0 0.4rem;
    color: var(--primary);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .guestbook-header h1 {
    margin: 0 0 0.75rem;
    color: var(--text-primary);
    font-size: 2rem;
    font-weight: 800;
  }

  .guestbook-intro {
    max-width: 40rem;
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .guestbook-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-bottom: 1.75rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid var(--line-divider);
  }

  .guestbook-field-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .guestbook-form label {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .guestbook-form input,
  .guestbook-form textarea {
    width: 100%;
    border: 1px solid var(--line-divider);
    border-radius: 0.5rem;
    background: var(--btn-regular-bg);
    color: var(--text-primary);
    padding: 0.75rem 0.9rem;
    font: inherit;
    outline: none;
    transition:
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .guestbook-form textarea {
    resize: vertical;
    min-height: 8rem;
    line-height: 1.7;
  }

  .guestbook-counter {
    align-self: flex-end;
    margin-top: -0.25rem;
    color: var(--text-tertiary);
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
    transition: color 0.2s ease;
  }

  .guestbook-counter[data-state="near"] {
    color: #f59e0b;
  }

  :global(.guestbook-item-left) {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
  }

  :global(.guestbook-avatar) {
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    user-select: none;
    line-height: 1;
  }

  :global(.guestbook-inline-link) {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 0.15em;
    overflow-wrap: anywhere;
  }

  :global(.guestbook-inline-link:hover) {
    text-decoration-thickness: 0.12em;
  }

  :global(.guestbook-item-delete) {
    flex-shrink: 0;
    margin-left: 0.75rem;
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--line-divider);
    border-radius: 0.4rem;
    background: transparent;
    color: var(--text-tertiary);
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  :global(.guestbook-item-delete:hover) {
    border-color: #ef4444;
    color: #ef4444;
  }

  :global(.guestbook-item-delete:disabled) {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .guestbook-admin-panel {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 0.75rem 1rem;
    margin-bottom: 1.25rem;
    border: 1px dashed var(--primary);
    border-radius: 0.6rem;
    background: color-mix(in oklch, var(--primary) 8%, transparent);
  }

  .guestbook-admin-panel .admin-token-input {
    flex: 1;
    min-width: 12rem;
    border: 1px solid var(--line-divider);
    border-radius: 0.4rem;
    background: var(--btn-regular-bg);
    color: var(--text-primary);
    padding: 0.5rem 0.75rem;
    font: inherit;
    font-size: 0.9rem;
    outline: none;
  }

  .guestbook-admin-panel .admin-token-input:focus {
    border-color: var(--primary);
  }

  :global(.admin-active-tag) {
    color: var(--primary);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .guestbook-count {
    color: var(--text-tertiary);
    font-size: 1rem;
    font-weight: 500;
    margin-left: 0.25rem;
  }

  .guestbook-form input:focus,
  .guestbook-form textarea:focus {
    border-color: var(--primary);
    background: var(--card-bg);
  }

  .guestbook-honeypot {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }

  .guestbook-actions,
  .guestbook-list-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .guestbook-actions,
  .guestbook-list-header {
    gap: 1rem;
  }

  :global(.guestbook-item-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .guestbook-status {
    margin: 0;
    min-height: 1.5rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .guestbook-status[data-type="error"] {
    color: #ef4444;
  }

  .guestbook-status[data-type="success"] {
    color: var(--primary);
  }

  .guestbook-actions button,
  .guestbook-list-header button {
    min-height: 2.5rem;
