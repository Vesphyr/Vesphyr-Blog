---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import PostDetailLayout from "@components/post/PostDetailLayout.astro";
import { getSortedPosts } from "@utils/content-utils";
import { getPostUrl } from "@utils/url-utils";
import { getAllPostSlugs } from "@utils/post-routes.js";
import { profileConfig, siteConfig } from "../../config";
import { buildBlogPostingJsonLd } from "../../utils/blog-schema";

export async function getStaticPaths() {
  const blogEntries = await getSortedPosts();

  const paths: {
    params: { slug: string };
    props: { entry: CollectionEntry<"posts"> };
  }[] = [];

  for (const entry of blogEntries) {
    for (const slug of getAllPostSlugs(entry)) {
      paths.push({
        params: { slug },
        props: { entry },
      });
    }
  }

  return paths;
}

const { entry } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(entry);

const normalizedCategory = entry.data.category || undefined;
const canonicalPath = getPostUrl(entry);
const canonicalUrl = Astro.site
  ? new URL(canonicalPath, Astro.site).toString()
  : new URL(canonicalPath, Astro.url).toString();

const coverImage = entry.data.image;
let imageAbsoluteUrl: string | undefined;
if (coverImage) {
  if (coverImage.startsWith("http://") || coverImage.startsWith("https://")) {
    imageAbsoluteUrl = coverImage;
  } else if (coverImage.startsWith("/") && Astro.site) {
    imageAbsoluteUrl = new URL(coverImage, Astro.site).toString();
  }
}

const jsonLd = buildBlogPostingJsonLd({
  title: entry.data.title,
  description: entry.data.description,
  published: entry.data.published,
  updated: entry.data.updated,
  lang: entry.data.lang,
  authorName: profileConfig.name,
  siteUrl: Astro.site,
  pageUrl: canonicalUrl,
  imageUrl: imageAbsoluteUrl,
  wordCount: remarkPluginFrontmatter?.words,
  tags: entry.data.tags,
  category: normalizedCategory,
  defaultLang: siteConfig.lang,
});
---

<PostDetailLayout
  entry={entry}
  headings={headings}
  jsonLd={jsonLd}
  canonicalUrl={canonicalUrl}
  remarkPluginFrontmatter={remarkPluginFrontmatter}
>
  <Markdown class="mb-6 markdown-content onload-animation">
    <Content />
  </Markdown>
</PostDetailLayout>
