# Homepage HTML - short edge cache
/
  Cache-Control: public, max-age=60, s-maxage=300, stale-while-revalidate=3600

# All non-personalized HTML pages - edge cache (matches homepage policy)
# Keeps content fresh (s-maxage 5min) while serving stale during revalidation.
/about/
  Cache-Control: public, max-age=60, s-maxage=300, stale-while-revalidate=3600
/albums/
/albums/*
  Cache-Control: public, max-age=60, s-maxage=300, stale-while-revalidate=3600
/archive/
/archive/*
  Cache-Control: public, max-age=60, s-maxage=300, stale-while-revalidate=3600
/posts/
/posts/*
  Cache-Control: public, max-age=60, s-maxage=300, stale-while-revalidate=3600

# RSS/Atom CORS headers
/atom.xml
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET
  Access-Control-Max-Age: 86400

/rss.xml
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET
  Access-Control-Max-Age: 86400

# Static assets - immutable long-term cache (Astro hashes filenames)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Build-generated assets (post-build script output) - hashed filenames
/assets/*.css
  Cache-Control: public, max-age=31536000, immutable

/assets/*.js
  Cache-Control: public, max-age=31536000, immutable

/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Font files (legacy path) - long-term cache
/assets/font/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Image assets - long-term cache (30 days)
/assets/images/*
  Cache-Control: public, max-age=31536000, immutable
/assets/icons/*
  Cache-Control: public, max-age=31536000, immutable
/assets/posts/*
  Cache-Control: public, max-age=31536000, immutable

# Public image and font assets - immutable long-term cache
/images/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# JS files in public - medium cache
/js/*
  Cache-Control: public, max-age=86400

# CSS files in public - medium cache
/assets/css/*
  Cache-Control: public, max-age=86400

# Favicon - long-term cache
/favicon/*
  Cache-Control: public, max-age=31536000, immutable

# HTML pages - security headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; media-src 'self' https://*.music.126.net; font-src 'self' data:; connect-src 'self' https://api.iconify.design; frame-ancestors 'self'; base-uri 'self'; form-action 'self'
